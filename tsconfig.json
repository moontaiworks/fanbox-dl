{
  "compilerOptions": {
    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    // Specify what module code is generated
    "module": "esnext",
    // Use latest since there have no requirement to support older versions like browser
    "target": "es2020",
    "lib": ["es2024", "ESNext.Array", "ESNext.Collection", "ESNext.Iterator"],

    // Recommended Options
    "strict": true,
    "noUncheckedSideEffectImports": true,
    // Treat files as modules even if it doesn't use import/export
    "moduleDetection": "force",
    // Sometime the library types will be incorrect
    "skipLibCheck": true,

    // Specify how TypeScript looks up a file from a given module specifier
    "moduleResolution": "bundler",

    // Don't emit generated files to output.
    // This flag will be overwrite when building the project
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuild/.tsbuildinfo",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // Remove comments from output
    "removeComments": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    // Allow JSON modules to be imported
    "resolveJsonModule": true
  },
  "files": [],
  "exclude": ["node_modules", "dist", "build", "docs", "coverage"],
  "references": [
    { "path": "./src/tsconfig.json" },
    { "path": "./tests/tsconfig.json" },
    { "path": "./tests/tsconfig.check.json" },
    { "path": "./tsconfig.check.json" }
  ]
}
